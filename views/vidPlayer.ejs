<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Play-video</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }

        body {
            background: #111;
            color: white;
            overflow-x: hidden;
        }

        .navbar {
            padding: 20px;
        }

        .video-wrapper {
            width: 900px;
            max-width: 95%;
            border-radius: 18px;
            overflow: hidden;
            background: #000;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
            position: absolute;
            top: 20%;
            left: 25%;
        }

        .video-frame {
            position: relative;
            width: 100%;
            padding-top: 56.25%;
            background: black;
        }

        .video-frame iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none;
        }

        .top-bar {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            padding: 16px 20px;
            background: linear-gradient(to bottom, rgba(0, 0, 0, 0.7), transparent);
            color: white;
            z-index: 10;
            pointer-events: none;
        }

        .top-bar h2 {
            font-size: 20px;
            font-weight: 600;
        }

        .bottom-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            padding: 30px 20px 18px;
            background: linear-gradient(to top, rgba(0, 0, 0, 0.75), transparent);
            z-index: 10;
            pointer-events: none;
        }

        .logo {
            color: #e50914;
            font-size: 35px;
            font-weight: bold;
            letter-spacing: 1px;
        }


        .sidebar {
            position: fixed;
            right: -240px;
            top: 0;
            width: 240px;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.749);
            transition: all 0.5s ease;
            padding-top: 50px;
        }

        .sidebar a {
            display: block;
            line-height: 50px;
            text-decoration: none;
            color: #ffffff;
            padding-left: 10px;
            font-size: 24px;
            border-bottom: 2px solid rgb(79, 79, 79, 0.648);
            border-top: 2px solid black;

        }

        .sidebar a:hover {
            border-right: 5px solid red;
            color: #e50914;
        }

        #check {
            display: none;
        }

        #btn,
        #cancel {
            position: absolute;
            right: 1px;
            top: 8px;
            cursor: pointer;
            height: 30px;
            width: 30px;
            text-align: center;
            color: #ffffff;
            font-size: 30px;
            margin-right: 15px;
            caret-color: transparent;
            outline: none;
            transition: all 0.5s ease;
        }

        #cancel {
            opacity: 0;
            visibility: hidden;
        }

        #check:checked~label #btn {
            margin-right: 190px;
            opacity: 0;
            visibility: hidden;
        }

        #check:checked~label #cancel {
            margin-right: 190px;
            opacity: 1;
            visibility: visible;
            position: absolute;
            z-index: 99;
        }

        #check:checked~.sidebar {
            right: 0;
        }

        .dp {
            height: 100px;
            width: 100px;
            border-radius: 50%;
            border: 3px solid rgb(175, 175, 175);
            margin: auto;
            margin-top: 100px;
            position: absolute;
            z-index: 9;
            right: 70px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .dp img {
            height: 100px;
            width: 100px;
            border-radius: 50%;
            object-fit: cover;
            object-position: center;
        }

        .sidebar a #dp {
            border-bottom: none;
            border-top: none;
        }

        .info {
            position: absolute;
            right: 87px;
            margin-top: 200px;
        }

        @media(max-width:768px) {
            body {
                background-color: #000000e9;
            }

            .video-wrapper {
                width: 900px;
                max-width: 95%;
                border-radius: 18px;
                overflow: hidden;
                background: #000;
                box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
                position: absolute;
                z-index: -1;
                top: 80px;
                left: 11px;
            }

            #khoj {
                display: block;
            }


            .navbar {
                padding: 20px;
            }

            .nav-links {
                display: none;
            }

            .hero {
                padding: 20px;
            }

            .title {
                font-size: 50px;
            }

            .description {
                font-size: 15px;
            }

            .row {
                padding: 20px;
            }
        }
    </style>
</head>

<body>
    <div id="loader">

    <style>

    body{
      margin:0;
      background:black;
      
    }
    #loader{
      position:fixed;
      top:0;
      left:0;
      width:100%;
      height:100vh;

      background:black;

      display:flex;
      justify-content:center;
      align-items:center;

      transition:opacity 0.5s ease;
      z-index:9999;
    }

    #loader.hide{
      opacity:0;
      pointer-events:none;
    }
   
    .loader{
      height:100px;
      width:100px;

      border:8px solid #ddd;
      border-top:8px solid red;
      border-right-color:red;

      border-radius:50%;

      animation:rotate 1s linear infinite;

      position: absolute;
      top:40vh;
    }

    .loader img{
      width:100%;
      height:100%;
      border-radius: 50%;
      object-fit:contain;
    }

    @keyframes rotate{
      100%{
        transform:rotate(360deg);
      }
    }

  </style>
</head>

<body>

  <div id="loader">

    <div class="loader">
      <img src="assets/netflix.jpg" alt="">
    </div>

  </div>
  </div>



    <div class="navbar">
        <div class="left-nav">
            <div class="logo">NETFLIX</div>
        </div>

        <div id="khoj">
            <input type="checkbox" id="check">
            <label for="check"><span id="btn">☰</span></label>
            <label for="check"><span id="cancel">✖</span></label>
            <div class="sidebar">
                <a href="#"><span>Home</span></a>
                <a href="#"><span>Tv show</span></a>
                <a href="#"><span>Movies</span></a>
                <a href="#"><span>New & Popular</span></a>

                <a href="pfp.html" id="dp">
                    <div class="dp">
                        <img src="assets/pfp.jpg" alt="">
                    </div>
                    <div class="info">
                        profile

                    </div>
                </a>
            </div>
        </div>

    </div>
    <div class="video-wrapper">

        <div class="top-bar">
            <h2></h2>
        </div>

        <div class="video-frame">
            <iframe 
            id="player"
            src="" 
            width="560" 
            height="384" 
            frameborder="0" 
            webkitallowfullscreen="true"
            mozallowfullscreen="true" allowfullscreen>
            </iframe>
        </div>


    </div>
    <script>
        let movie = localStorage.getItem("movieLink");
        document.getElementById("player").src = movie;

        window.onload = function () {

      setTimeout(() => {

        document.getElementById("loader").classList.add("hide");

      }, 200);

    };
    </script>
</body>

</html>