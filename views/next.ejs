  <div id="loader">

    <style>
      body {
        margin: 0;
        background: black;

      }

      #loader {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;

        background: black;

        display: flex;
        justify-content: center;
        align-items: center;

        transition: opacity 0.5s ease;
        z-index: 9999;
      }

      #loader.hide {
        opacity: 0;
        pointer-events: none;
      }

      .loader {
        height: 100px;
        width: 100px;

        border: 8px solid #ddd;
        border-top: 8px solid red;
        border-right-color: red;

        border-radius: 50%;

        animation: rotate 1s linear infinite;

        position: absolute;
        top: 40vh;
      }

      .loader img {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: contain;
      }

      @keyframes rotate {
        100% {
          transform: rotate(360deg);
        }
      }
    </style>
    </head>

