<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>preview page</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, Helvetica, sans-serif;
    }

    body {
      background: #111;
      color: white;
      overflow-x: hidden;
    }


    .navbar {
      width: 100%;
      padding: 20px 60px;
      position: fixed;
      top: 0;
      left: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: linear-gradient(to bottom, rgba(0, 0, 0, 0.8), transparent);
    }

    .left-nav {
      display: flex;
      align-items: center;
      gap: 40px;
    }

    .logo {
      color: #e50914;
      font-size: 35px;
      font-weight: bold;
      letter-spacing: 1px;
    }

    .nav-links {
      display: flex;
      gap: 25px;
    }

    .nav-links a {
      text-decoration: none;
      color: white;
      font-size: 15px;
      transition: 0.3s;
    }

    .nav-links a:hover {
      color: #b3b3b3;
    }


    .hero {
      height: 85vh;
      background-size: cover;
      background-position: center;
      display: flex;
      align-items: center;
      padding: 0 60px;

    }

    .hero-content {
      max-width: 550px;
    }

    .series {
      color: #ccc;
      letter-spacing: 3px;
      margin-bottom: 15px;
    }

    .title {
      font-size: 80px;
      font-weight: bold;
      margin-bottom: 20px;
      margin-top: 16px;
      font-family: Georgia, serif;
      color: white;
    }

    .details {
      color: #ddd;
      margin-bottom: 20px;
      font-size: 15px;
      color: #b3b3b3;
    }

    .description {
      line-height: 1.7;
      font-size: 18px;
      color: #eee;
      margin-bottom: 30px;
    }

    .buttons {
      display: flex;
      gap: 15px;
    }

    .btn {
      padding: 14px 28px;
      border: none;
      border-radius: 6px;
      font-size: 16px;
      font-weight: bold;
      cursor: pointer;
      transition: 0.3s;
    }

    .btn-white {
      background: white;
      color: black;
    }

    .btn-white:hover {
      background: #ddd;
    }

    .btn-dark {
      background: rgba(109, 109, 110, 0.7);
      color: white;
    }

    .btn-dark:hover {
      background: rgba(109, 109, 110, 0.4);
    }


    .row {
      padding: 20px 60px;
      margin-top: -120px;
      position: relative;
      z-index: 10;
    }

    .row h2 {
      margin-bottom: 20px;
      font-size: 24px;
    }

    .cards {
      display: flex;
      gap: 15px;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .cards::-webkit-scrollbar {
      display: none;
    }

    .card {
      min-width: 250px;
      height: 140px;
      border-radius: 10px;
      overflow: hidden;
      transition: 0.3s;
      cursor: pointer;
    }

    .card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .card:hover {
      transform: scale(1.08);
    }

    .sidebar {
      position: fixed;
      right: -240px;
      top: 0;
      width: 240px;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.749);
      transition: all 0.5s ease;
      padding-top: 50px;
    }

    .sidebar a {
      display: block;
      line-height: 50px;
      text-decoration: none;
      color: #ffffff;
      padding-left: 10px;
      font-size: 24px;
      border-bottom: 2px solid rgb(79, 79, 79, 0.648);
      border-top: 2px solid black;

    }

    .sidebar a:hover {
      border-right: 5px solid red;
      color: #e50914;
    }

    #check {
      display: none;
    }

    #btn,
    #cancel {
      position: absolute;
      right: 1px;
      top: 8px;
      cursor: pointer;
      height: 30px;
      width: 30px;
      text-align: center;
      color: #ffffff;
      font-size: 30px;
      margin-right: 15px;
      caret-color: transparent;
      outline: none;
      transition: all 0.5s ease;
    }

    #cancel {
      opacity: 0;
      visibility: hidden;
    }

    #check:checked~label #btn {
      margin-right: 190px;
      opacity: 0;
      visibility: hidden;
    }

    #check:checked~label #cancel {
      margin-right: 190px;
      opacity: 1;
      visibility: visible;
      position: absolute;
      z-index: 99;
    }

    #check:checked~.sidebar {
      right: 0;
    }

    .dp {
      height: 100px;
      width: 100px;
      border-radius: 50%;
      border: 3px solid rgb(175, 175, 175);
      margin: auto;
      margin-top: 100px;
      position: absolute;
      z-index: 9;
      right: 70px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .dp img {
      height: 100px;
      width: 100px;
      border-radius: 50%;
      object-fit: cover;
      object-position: center;
    }

    .sidebar a #dp {
      border-bottom: none;
      border-top: none;
    }

    .info {
      position: absolute;
      right: 87px;
      margin-top: 200px;
    }

    @media(max-width:768px) {
      .hero {
        height: 85vh;
        background-size: contain;
        background-repeat: no-repeat;
        background-position: top;
        display: flex;
        align-items: center;
        padding: 0 60px;
        margin-top: 65px;

      }

      #khoj {
        display: block;
      }

      .row {
        padding: 20px 60px;
        margin-top: -120px;
        position: relative;
        z-index: 10;
      }

      .cards {
        display: flex;
        gap: 10px;

        scrollbar-width: none;
      }

      .card {
        width: 60px;
        height: 140px;
        border-radius: 10px;
        overflow: hidden;
        transition: 0.3s;
        cursor: pointer;
      }

      .hero-content {
        margin-top: 100px;
      }

      .navbar {
        padding: 20px;
      }

      .nav-links {
        display: none;
      }

      .hero {
        padding: 20px;
      }

      .title {
        font-size: 50px;
      }

      .description {
        font-size: 15px;
      }

      .row {
        padding: 20px;
      }
    }
  </style>
</head>

<body>
  <div id="loader">

    <style>

    body{
      margin:0;
      background:black;
      
    }
    #loader{
      position:fixed;
      top:0;
      left:0;
      width:100%;
      height:100vh;

      background:black;

      display:flex;
      justify-content:center;
      align-items:center;

      transition:opacity 0.5s ease;
      z-index:9999;
    }

    #loader.hide{
      opacity:0;
      pointer-events:none;
    }
   
    .loader{
      height:100px;
      width:100px;

      border:8px solid #ddd;
      border-top:8px solid red;
      border-right-color:red;

      border-radius:50%;

      animation:rotate 1s linear infinite;

      position: absolute;
      top:40vh;
    }

    .loader img{
      width:100%;
      height:100%;
      border-radius: 50%;
      object-fit:contain;
    }

    @keyframes rotate{
      100%{
        transform:rotate(360deg);
      }
    }

  </style>
</head>

<body>

  <div id="loader">

    <div class="loader">
      <img src="assets/netflix.jpg" alt="">
    </div>

  </div>
  </div>



  <div id="main-content">
    <div class="navbar">
      <div class="left-nav">
        <div class="logo">NETFLIX</div>
      </div>

      <div id="khoj">
        <input type="checkbox" id="check">
        <label for="check"><span id="btn">☰</span></label>
        <label for="check"><span id="cancel">✖</span></label>
        <div class="sidebar">
          <a href="#"><span>Home</span></a>
          <a href="#"><span>Tv show</span></a>
          <a href="#"><span>Movies</span></a>
          <a href="#"><span>New & Popular</span></a>

          <a href="pfp.html" id="dp">
            <div class="dp">
              <img src="assets/pfp.jpg" alt="">
            </div>
            <div class="info">
              profile

            </div>
          </a>
        </div>
      </div>

    </div>


    <section class="hero">

      <div class="hero-content">

        <p class="series">NETFLIX SERIES</p>

        <h1 class="title"></h1>

        <p class="details">
          Show • Fantasy • 2022 • TV-14
        </p>

        <p class="description">
        </p>

        <div class="buttons">

          <button class="btn btn-white" onclick="play(A)">
            ▶ Play
          </button>

          <button class="btn btn-dark">
            More Info
          </button>

        </div>

      </div>

    </section>


    <section class="row">

      <h2>Trending Now</h2>

      <div class="cards">

        <div class="card">
          <img src="assets/p6.png">
        </div>

        <div class="card">
          <img src="assets/p1.jpg">
        </div>

        <div class="card">
          <img src="assets/p2.jpg">
        </div>

        <div class="card">
          <img src="assets/p5.jpg">
        </div>

      </div>

    </section>
  </div>



  <script src="prev.js"></script>
  <script>
    function play(link) {
      localStorage.setItem("movieLink", link);
      window.location.href = "vidPlayer.html"
    };


    window.onload = function () {

      setTimeout(() => {

        document.getElementById("loader").classList.add("hide");

      }, 200);

    };


  </script>


</body>

</html>